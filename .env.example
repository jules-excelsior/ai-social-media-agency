PORT=3000
ADMIN_PASSWORD=admin2025

# Set either (or both) so ALL users can generate without entering their own key.
# Leave blank to require each user to enter their own key.
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# DeepSeek API key (optional). Set for server-side DeepSeek support.
# Users can still bring their own key if this is left blank.
DEEPSEEK_API_KEY=

# Optional: set a default model
# DEFAULT_MODEL=claude-opus-4-8

# Optional: default provider ('claude' or 'deepseek')
# DEFAULT_PROVIDER=claude
